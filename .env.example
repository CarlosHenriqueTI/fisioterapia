# =====================================================
# CONFIGURAÇÃO DO SUPABASE - TEMPLATE
# =====================================================

# IMPORTANTE: Copie este arquivo para .env e substitua pelos valores reais

# URL do seu projeto Supabase
# Encontre em: Supabase Dashboard > Settings > API > Project URL
EXPO_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública (anon key) do seu projeto Supabase  
# Encontre em: Supabase Dashboard > Settings > API > Project API keys > anon public
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua_chave_publica_aqui

# Chave de serviço (service role) - MANTER SECRETA
# Encontre em: Supabase Dashboard > Settings > API > Project API keys > service_role
EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=sua_chave_de_servico_aqui

# =====================================================
# CONFIGURAÇÕES ADICIONAIS (OPCIONAIS)
# =====================================================

# Configurações de desenvolvimento
NODE_ENV=development
DEBUG=true

# Configurações do app
EXPO_PUBLIC_APP_NAME=BM Espaço Saúde
EXPO_PUBLIC_APP_VERSION=1.0.0

# Configurações de desenvolvimento
EXPO_PUBLIC_DEV_MODE=true
